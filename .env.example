PORT=3000
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string-in-production
ADMIN_EMAIL=admin@school.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Al Kharran Primary School Administrator

# Set to true only when you need to reset the admin password from ADMIN_PASSWORD on restart
# ADMIN_SYNC_PASSWORD=true

# Demo/sample data seeding — disabled in production by default
# SEED_DEMO_DATA=true

# Show login credential hints on the sign-in page (off in production unless set)
# SHOW_LOGIN_HINTS=true

# Required on Render (free tier). Create free database at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional — only if frontend is on GitHub Pages:
# CORS_ORIGIN=https://YOUR-USERNAME.github.io
